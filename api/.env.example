# Neon: pegue as duas URLs no dashboard do projeto.
# DATABASE_URL = connection string "Pooled connection" (host com "-pooler")
# DIRECT_URL   = connection string direta (sem "-pooler"), usada só p/ migrations
# Em dev local (sem pooler) pode deixar as duas iguais.
DATABASE_URL="postgresql://user:password@localhost:5432/conectvet?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/conectvet?schema=public"

JWT_SECRET="troque-este-valor-em-producao"
JWT_EXPIRES_IN="7d"
PORT=3333

# URL do frontend em produção, usada para restringir o CORS.
# Em branco/ausente libera qualquer origem (ok para dev local).
CORS_ORIGIN=""

# Credenciais do admin criado pelo seed (ajuste antes de rodar em produção)
ADMIN_EMAIL="admin@conectvet.com"
ADMIN_SENHA="troque-esta-senha"
